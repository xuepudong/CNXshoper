# 上传目录安全兜底：禁止执行任何脚本，防止木马上传后被访问执行
# 即使根目录 .htaccess 被覆盖，本文件仍独立生效

# 关闭 PHP 引擎（Apache + mod_php）
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>

# 拦截各类脚本文件的直接访问
<FilesMatch "\.(php|php3|php4|php5|php7|php8|phtml|pht|phar|cgi|pl|py|sh|asp|aspx|jsp)$">
    Require all denied
</FilesMatch>
